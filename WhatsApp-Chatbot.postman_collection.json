  "item": [
    {
      "name": "Hi -> Hello",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sender\": \"+91-9876543210\",\n  \"message\": \"Hi\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/webhook",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "webhook"
          ]
        },
        "description": "Checks the standard greeting flow."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Reply is Hello\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.reply).to.eql(\"Hello\");",
              "});"
            ]
          }
        }
      ],
      "response": []
    },
